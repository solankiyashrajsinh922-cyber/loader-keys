{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "reseller.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/([a-zA-Z0-9_-]+)/login",
      "dest": "/reseller.html"
    },
    {
      "src": "/([a-zA-Z0-9_-]+)",
      "dest": "/reseller.html"
    }
  ]
}
