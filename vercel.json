{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/reseller",
      "dest": "/reseller.html"
    },
    {
      "src": "/reseller.html",
      "dest": "/reseller.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
